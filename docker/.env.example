# ══════════════════════════════════════════════════════════════
# Environment variables untuk docker-compose
# Copy file ini ke `.env` lalu sesuaikan kebutuhan.
#   cp .env.example .env
# ══════════════════════════════════════════════════════════════

# ── TTS audio driver ─────────────────────────────────────────
# dummy  = silent (default, aman di mana saja)
# alsa   = Linux host dengan ALSA
# pulse  = Linux host dengan PulseAudio (perlu mount socket)
SDL_AUDIODRIVER=dummy

# Aktifkan/non-aktifkan TTS. Kalau false, mp3 tidak di-generate sama sekali.
ENABLE_TTS=true

# Timezone untuk logging
TZ=Asia/Jakarta
